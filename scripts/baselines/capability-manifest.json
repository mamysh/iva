{
  "schemaVersion": 1,
  "product": {
    "name": "iva",
    "version": "0.3.0-rc.4"
  },
  "agent": {
    "source": "agent/agent.ts",
    "providerRoute": {
      "selector": "MODEL_PROVIDER",
      "default": "ollama",
      "providers": [
        "codex",
        "ollama",
        "opencode",
        "openrouter"
      ],
      "textModelSource": "agent/agent.ts",
      "visionModelSource": "agent/vision.ts",
      "configurationSource": "scripts/lib/model-profile.mjs",
      "runtimeAdapterSource": "agent/provider.ts",
      "roleContractSource": "scripts/baselines/model-role-contract.json",
      "roleContract": {
        "schemaVersion": 1,
        "roles": {
          "text": {
            "providerSelector": "MODEL_PROVIDER",
            "providerDefault": "ollama",
            "configurationSource": "scripts/lib/model-profile.mjs"
          },
          "vision": {
            "providerSelector": "VISION_PROVIDER",
            "defaultFollowsRole": "text",
            "configurationSource": "scripts/lib/model-profile.mjs"
          },
          "effort": {
            "selector": "THINKING_EFFORT",
            "supportedProviders": [
              "codex"
            ]
          }
        },
        "providers": {
          "codex": {
            "textModelSelector": "CODEX_MODEL",
            "textDefault": "gpt-5.5",
            "textSelection": "authenticated-inventory",
            "toolCalling": "required",
            "visionModelSelector": "CODEX_VISION_MODEL",
            "visionDefault": "text-model",
            "visionSelection": "configured-text-fallback",
            "liveInventory": true
          },
          "ollama": {
            "textModelSelector": "OLLAMA_MODEL",
            "textDefault": "deepseek-v4-pro",
            "textSelection": "authenticated-inventory",
            "toolCalling": "required",
            "visionModelSelector": "OLLAMA_VISION_MODEL",
            "visionDefault": "minimax-m3",
            "visionSelection": "configured-default",
            "liveInventory": true
          },
          "opencode": {
            "textModelSelector": "OPENCODE_MODEL",
            "textDefault": "deepseek-v4-pro",
            "textSelection": "curated-static",
            "toolCalling": "required",
            "visionModelSelector": "OPENCODE_VISION_MODEL",
            "visionDefault": "gemini-3-flash",
            "visionSelection": "configured-default",
            "liveInventory": false
          },
          "openrouter": {
            "textModelSelector": "OPENROUTER_MODEL",
            "textDefault": "openai/gpt-5.1",
            "textSelection": "manual-live-probe",
            "toolCalling": "required",
            "visionModelSelector": "OPENROUTER_VISION_MODEL",
            "visionDefault": "google/gemini-2.5-flash",
            "visionSelection": "configured-default",
            "liveInventory": false
          }
        }
      }
    },
    "capabilities": {
      "tools": [
        "bash",
        "glob",
        "grep",
        "memory_search",
        "read_file",
        "reminders",
        "tasks",
        "web_search",
        "write_card",
        "write_file"
      ],
      "skills": [
        "agent-browser",
        "google-workspace",
        "morning-digest",
        "security-defense",
        "telegram-userbot",
        "web-research"
      ],
      "hooks": [
        "transcript",
        "usage"
      ],
      "channels": [
        "eve",
        "telegram"
      ],
      "connections": [
        "telegram-userbot"
      ],
      "subagents": [
        "planner"
      ]
    }
  },
  "controls": {
    "telegram": {
      "bridgeSource": "scripts/telegram-poll.mjs",
      "bridgeOwnedCommands": [
        "/help",
        "/usage",
        "/reminders",
        "/restart",
        "/new",
        "/clear",
        "/compact",
        "/update",
        "/model",
        "/think"
      ],
      "modelConfiguration": {
        "commands": [
          "/model",
          "/think"
        ],
        "roles": [
          "text",
          "vision",
          "effort"
        ],
        "wizardSource": "scripts/lib/model-wizard.mjs",
        "applySource": "scripts/lib/model-config-transaction.mjs",
        "probeSource": "scripts/model-config-probe.mjs",
        "callbackTtlSeconds": 300,
        "restartScope": "iva.service"
      },
      "delivery": {
        "securityBeforeTransport": true,
        "selectorSource": "scripts/lib/telegram-format.mjs",
        "orchestrationSource": "scripts/lib/telegram-delivery.mjs",
        "fallbackOrder": [
          "rich",
          "html",
          "plain"
        ]
      }
    }
  },
  "systemd": {
    "managedServices": [
      "iva-telegram-poll.service",
      "iva.service"
    ],
    "managedTimers": [
      "iva-memory-daily.timer",
      "iva-memory-doctor.timer",
      "iva-memory-monthly.timer",
      "iva-memory-weekly.timer",
      "iva-memory-yearly.timer",
      "iva-observe.timer",
      "iva-reminders.timer",
      "iva-update-check.timer"
    ],
    "defaultTimers": [
      "iva-memory-daily.timer",
      "iva-memory-doctor.timer",
      "iva-memory-monthly.timer",
      "iva-memory-weekly.timer",
      "iva-memory-yearly.timer",
      "iva-observe.timer",
      "iva-reminders.timer"
    ],
    "optionalTimers": [
      "iva-update-check.timer"
    ],
    "timerTriggeredServices": [
      "iva-memory-daily.service",
      "iva-memory-doctor.service",
      "iva-memory-monthly.service",
      "iva-memory-weekly.service",
      "iva-memory-yearly.service",
      "iva-observe.service",
      "iva-reminders.service",
      "iva-update-check.service"
    ],
    "optionalServices": [
      "iva-telegram-userbot.service"
    ],
    "templates": [
      "iva-memory-daily.service",
      "iva-memory-daily.timer",
      "iva-memory-doctor.service",
      "iva-memory-doctor.timer",
      "iva-memory-monthly.service",
      "iva-memory-monthly.timer",
      "iva-memory-weekly.service",
      "iva-memory-weekly.timer",
      "iva-memory-yearly.service",
      "iva-memory-yearly.timer",
      "iva-observe.service",
      "iva-observe.timer",
      "iva-reminders.service",
      "iva-reminders.timer",
      "iva-telegram-poll.service",
      "iva-telegram-userbot.service",
      "iva-update-check.service",
      "iva-update-check.timer"
    ]
  },
  "extensions": {
    "contractVersion": 1,
    "contractSource": "scripts/extension-contracts.json",
    "types": [
      "provider",
      "tool",
      "skill",
      "channel-connection",
      "hook",
      "subagent",
      "background-job-timer",
      "memory-processor-indexer"
    ],
    "examples": [
      "examples/extensions/provider.ts.txt",
      "examples/extensions/tool.ts.txt",
      "examples/extensions/skill.md.txt",
      "examples/extensions/connection.ts.txt",
      "examples/extensions/hook.ts.txt",
      "examples/extensions/subagent/agent.ts.txt",
      "examples/extensions/background-job.mjs.txt",
      "examples/extensions/memory-processor.ts.txt"
    ],
    "backgroundPolicy": "managed-oneshot-only",
    "optionalFeatures": [
      {
        "name": "telegram-userbot",
        "status": "beta",
        "activation": "iva userbot setup"
      },
      {
        "name": "update-notifications",
        "status": "stable",
        "activation": "iva update-check on"
      }
    ]
  },
  "storage": {
    "contractVersion": 1,
    "selector": [
      "WORKFLOW_TARGET_WORLD"
    ],
    "defaultProfile": "local",
    "profiles": [
      {
        "name": "local",
        "world": "@workflow/world-local",
        "bundled": true
      },
      {
        "name": "postgres",
        "world": "@workflow/world-postgres",
        "bundled": false,
        "optIn": true
      }
    ],
    "configurationSource": "scripts/lib/workflow-config.mjs",
    "buildDescriptor": ".output/iva-workflow-profile.json",
    "postgresEnableCommand": "iva workflow-postgres enable",
    "postgresIntegrationGate": "npm run replica:postgres",
    "lifecycle": {
      "updateCommand": "iva update",
      "updateTransactionSource": "scripts/update-runtime.mjs",
      "updateLockSource": "scripts/lib/update-lock.mjs",
      "updateProgressSource": "scripts/lib/update-progress.mjs",
      "updateNotificationSource": "scripts/lib/update-notification.mjs",
      "updateNotificationState": "${ASSISTANT_DATA_DIR}/update-notification-state.json",
      "updateMigrationManifest": "scripts/update-manifest.json",
      "localWorkflowState": ".eve/.workflow-data",
      "legacyLocalWorkflowState": ".workflow-data",
      "localWorkflowMigrationSource": "scripts/lib/local-workflow-state.mjs",
      "backupCommand": "iva backup",
      "restoreCommand": "iva restore <portable-backup-directory>",
      "dataManifest": "scripts/data-manifest.json",
      "portableBackupSource": "scripts/lib/portable-backup.mjs",
      "portableBackupSchemaVersion": 1,
      "doctorCommand": "iva doctor",
      "doctorJsonCommand": "iva doctor --json",
      "doctorSchemaVersion": 1,
      "doctorSource": "scripts/doctor.mjs",
      "statusCommand": "iva status",
      "observabilitySource": "scripts/lib/health-metrics.mjs",
      "observabilitySchemaVersion": 1,
      "observabilityRetentionSamples": 744,
      "observabilityCollector": "iva-observe.timer",
      "restartCommand": "iva restart",
      "recoverCommand": "iva recover",
      "resetCommand": "iva reset",
      "diagnosticsSource": "scripts/workflow-health.mjs",
      "purgeCommand": null
    }
  },
  "runtime": {
    "node": "24.x",
    "eve": "0.24.4",
    "workflow": [
      {
        "name": "@workflow/errors",
        "version": "5.0.0-beta.10"
      },
      {
        "name": "@workflow/serde",
        "version": "4.1.0"
      },
      {
        "name": "@workflow/utils",
        "version": "5.0.0-beta.6"
      },
      {
        "name": "@workflow/world",
        "version": "5.0.0-beta.17"
      },
      {
        "name": "@workflow/world-local",
        "version": "5.0.0-beta.28"
      },
      {
        "name": "@workflow/world-postgres",
        "version": "5.0.0-beta.23"
      }
    ]
  }
}
