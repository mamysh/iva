{
  "name": "iva",
  "version": "0.2.5",
  "type": "module",
  "bin": {
    "iva": "bin/iva.mjs"
  },
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "iva": "node bin/iva.mjs",
    "setup": "node scripts/setup.mjs",
    "check-port": "node scripts/check-port.mjs",
    "build": "node scripts/build.mjs",
    "dev": "eve dev",
    "start": "node scripts/start.mjs",
    "init-vault": "node scripts/init-vault.mjs",
    "digest": "node scripts/daily-digest.ts",
    "reminders": "node --env-file=.env scripts/reminders-run.mjs",
    "poll": "node --env-file=.env scripts/telegram-poll.mjs",
    "memory": "node --env-file=.env scripts/memory/rollup.ts",
    "doctor": "node --env-file=.env scripts/memory/doctor.ts",
    "workflow:smoke": "node --env-file=.env scripts/workflow-smoke.mjs",
    "manifest": "node scripts/capability-manifest.mjs",
    "canary:core": "node scripts/check-core-canaries.mjs",
    "replica:local": "node scripts/replica-smoke.mjs",
    "replica:postgres": "node scripts/replica-smoke.mjs --postgres",
    "replica:install": "node scripts/clean-install-smoke.mjs",
    "baseline:resources": "node scripts/replica-smoke.mjs --baseline",
    "verify:pr": "npm test && npm run typecheck && npm run build",
    "typecheck": "tsgo",
    "test": "node scripts/check-reasoning-strip.mjs && node scripts/check-workflow-config.mjs && node scripts/check-reminders-store.mjs && node scripts/check-telegram-update.mjs && node scripts/check-memory-guards.mjs && node scripts/check-integration-invariants.mjs && node scripts/check-capability-manifest.mjs && node scripts/check-core-canaries.mjs && node scripts/check-install-readiness.mjs && node scripts/check-test-policy.mjs && node scripts/check-public-docs.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0-beta.76",
    "@ai-sdk/openai-compatible": "^3.0.0-beta.57",
    "@vercel/connect": "0.2.2",
    "@workflow/world-postgres": "5.0.0-beta.23",
    "ai": "7.0.0-beta.178",
    "eve": "0.11.10",
    "just-bash": "^3.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "patch-package": "^8.0.1"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  }
}
