# Провайдер модели: ollama | opencode (оба OpenAI-совместимы, работают с RU-IP).
MODEL_PROVIDER=ollama

# Ollama Cloud (если MODEL_PROVIDER=ollama)
OLLAMA_API_KEY=ollama-...
OLLAMA_MODEL=deepseek-v4-pro
# Окно контекста: НЕ завышай — компактация считает порог от него (overflow-риск).
OLLAMA_CONTEXT_WINDOW=131072

# OpenCode Zen/Go (если MODEL_PROVIDER=opencode) — https://opencode.ai/auth
OPENCODE_API_KEY=
OPENCODE_MODEL=opencode-go/deepseek-v4-pro
OPENCODE_CONTEXT_WINDOW=131072

# Vision fallback для картинок из Telegram.
# По умолчанию TELEGRAM_IMAGE_MODE=describe: картинка сначала читается vision-моделью,
# а основной агент получает текстовое описание. Так DeepSeek/другие текстовые модели
# не падают на image_url. Если основная модель точно vision — можно поставить native.
TELEGRAM_IMAGE_MODE=describe
VISION_BASE_URL=https://ollama.com/v1
VISION_MODEL=minimax-m3
VISION_TIMEOUT_MS=120000
VISION_MAX_OUTPUT_TOKENS=900
# Если пусто, используется OLLAMA_API_KEY. Для OpenCode укажите отдельный ключ Ollama.
VISION_API_KEY=

# Браузер agent-browser: потолок вывода (защита окна контекста).
AGENT_BROWSER_MAX_OUTPUT=24000

# Telegram-бот (для канала и дайджеста)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_BOT_USERNAME=my_bot
TELEGRAM_WEBHOOK_SECRET_TOKEN=придумай_длинную_строку
# БЕЗОПАСНОСТЬ: бот отвечает ТОЛЬКО этим user ID (через запятую). Пусто = не отвечает никому.
# Свой ID: напиши @userinfobot или запусти `npm run setup` (автоопределение).
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_DIGEST_CHAT_ID=         # твой chat_id для утреннего дайджеста

# Telegram MCP (чтение истории чатов через user-аккаунт, chigwell/telegram-mcp).
# Настройка:
#   npm run telegram:mcp:setup
#   npm run telegram:mcp:session -- --qr
# Затем заполни API ID/HASH/session string ниже и запусти `npm run telegram:mcp:serve`
# или systemd unit `iva-telegram-mcp.service`.
TELEGRAM_MCP_URL=http://127.0.0.1:8765/mcp
TELEGRAM_MCP_HOST=127.0.0.1
TELEGRAM_MCP_PORT=8765
TELEGRAM_MCP_PATH=/mcp
TELEGRAM_MCP_TRANSPORT=streamable-http
TELEGRAM_MCP_DIR=data/telegram-mcp
TELEGRAM_MCP_REPO=https://github.com/chigwell/telegram-mcp.git
TELEGRAM_MCP_REF=ae914c05466f52acc269368a36d95bc0c4339bca
TELEGRAM_EXPOSED_TOOLS=read-only
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Deepgram — транскрипция голоса/видео из Telegram (nova-3)
# Ключ: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=
# Язык распознавания. multi = автоопределение (ru/uz/en и др.).
DEEPGRAM_LANGUAGE=multi

# Часовой пояс (IANA). Используется для дат daily-транскрипта, систем­ных
# таймеров памяти и динамической инструкции now. Пробрасывается в TZ.
ASSISTANT_TIMEZONE=Europe/Minsk

# Каталог ЖИВОГО vault (память + Obsidian + git-бэкап). Относительный или абсолютный.
# Отдельный приватный git-репо; создаётся из vault-template/ через `npm run init-vault`.
ASSISTANT_VAULT_DIR=vault

# Хранилище задач (необязательно; по умолчанию ./data)
ASSISTANT_DATA_DIR=data

# Для cron-скрипта на VPS (необязательно)
ASSISTANT_HOST=http://127.0.0.1:3000
# ASSISTANT_BEARER=                # если eve-канал в проде требует bearer-токен
