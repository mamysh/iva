# Non-secret defaults for Iva's durable Workflow backend.
# Values in the project's .env override this file because it is loaded later.
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_QUEUE_NAMESPACE=eve
WORKFLOW_POSTGRES_URL=postgresql:///iva_workflow?host=/var/run/postgresql
WORKFLOW_POSTGRES_JOB_PREFIX=iva_
WORKFLOW_POSTGRES_WORKER_CONCURRENCY=8
WORKFLOW_POSTGRES_MAX_POOL_SIZE=10
