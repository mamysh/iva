[Unit]
Description=Iva lightweight health metrics collector
After=iva.service

[Service]
Type=oneshot
RuntimeMaxSec=5min
WorkingDirectory=__PROJECT_DIR__
EnvironmentFile=__PROJECT_DIR__/.env
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=__NODE_BIN__ --env-file=.env scripts/observe.mjs collect
